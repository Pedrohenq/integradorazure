# ──────────────────────────────────────────────────────────────
# Firebase - Projeto Firestore
# Copie os valores do Console Firebase → Configurações do Projeto → Seus apps → Web
# ──────────────────────────────────────────────────────────────
REACT_APP_FIREBASE_API_KEY=sua_api_key_aqui
REACT_APP_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=seu-projeto-id
REACT_APP_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# IMPORTANTE: Regras do Firestore
# No Console Firebase → Firestore → Regras, cole:
#
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /{document=**} {
#       allow read, write: if true;
#     }
#   }
# }
# ──────────────────────────────────────────────────────────────
